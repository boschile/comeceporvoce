# ─────────────────────────────────────────────────────────────
#  NÚCLEO — variáveis de ambiente
#  Copie para .env e preencha. Nada aqui é obrigatório para rodar
#  em desenvolvimento (o app degrada com elegância), mas você
#  precisará das chaves reais para e-mail, WhatsApp e rastreamento.
# ─────────────────────────────────────────────────────────────

# Banco de dados — Postgres (produção e desenvolvimento).
# Local: rode um Postgres ou use uma URL do Neon (https://neon.tech).
# Formato: postgresql://USUARIO:SENHA@HOST/BANCO?sslmode=require
# No Neon/Netlify, copie a connection string pronta e cole aqui.
DATABASE_URL="postgresql://user:password@localhost:5432/nucleo?schema=public"

# URL pública do site (usada em SEO, sitemap e links do PDF/e-mail)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Painel administrativo ─────────────────────────────────────
# Senha do admin e segredo para assinar o cookie de sessão.
ADMIN_PASSWORD="troque-esta-senha"
ADMIN_SESSION_SECRET="gere-uma-string-aleatoria-longa"

# ── SMTP (envio do relatório por e-mail) ──────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Núcleo <nao-responda@seudominio.com.br>"

# ── WhatsApp ──────────────────────────────────────────────────
# Número no formato internacional só com dígitos (ex.: 5511999999999).
# Usado para gerar links wa.me no funil e no painel.
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# ── Rastreamento (client-side, carregados só após consentimento) ─
NEXT_PUBLIC_GTM_ID=""            # ex.: GTM-XXXXXXX
NEXT_PUBLIC_GA4_ID=""           # ex.: G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=""    # ex.: 000000000000000

# ── Meta Conversions API (server-side) ────────────────────────
META_CAPI_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""
META_CAPI_TEST_CODE=""          # opcional, para o Events Manager

# ── Anti-spam ─────────────────────────────────────────────────
# Cloudflare Turnstile (opcional). Sem isso, usamos honeypot + time-trap.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
